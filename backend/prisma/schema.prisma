generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ORGANIZER
  PARTICIPANT
  ADMIN
  VENDOR
  VOLUNTEER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ServiceCategory {
  CATERING
  DECORATION
  SOUND
  PHOTO
  SECURITY
}

enum PaymentProvider {
  CLICK
  PAYME
  STRIPE
}

enum VolunteerStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  firstName    String
  lastName     String
  roles        Role[]   @default([PARTICIPANT])
  activeRole   Role     @default(PARTICIPANT)
  avatarUrl    String?
  isVerified   Boolean  @default(false)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events          Event[]
  tickets         Ticket[]
  reviews         Review[]
  volunteerApps   VolunteerApplication[]
  ownedVenues     Venue[]              @relation("VenueOwner")
  ownedServices   Service[]            @relation("ServiceVendor")
  venueBookings   VenueBooking[]
  ticketPayments  TicketPayment[]
  venuePayments   VenueBookingPayment[]
  servicePayments ServicePayment[]
}

model Event {
  id          String      @id @default(uuid())
  organizerId String
  organizer   User        @relation(fields: [organizerId], references: [id])
  title       String
  description String?
  bannerUrl   String[]
  startDate   DateTime
  endDate     DateTime
  eventType   String
  capacity    Int
  status      EventStatus @default(DRAFT)
  venueId     String?
  venue       Venue?      @relation(fields: [venueId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tickets       Ticket[]
  ticketTiers   TicketTier[]
  services      EventService[]
  reviews       Review[]
  volunteerApps VolunteerApplication[]
  venueBooking  VenueBooking?
  ratingStats   RatingStats?
}

model TicketTier {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  name      String
  price     Decimal  @db.Decimal(12, 2)
  quantity  Int
  createdAt DateTime @default(now())

  tickets Ticket[]
}

model Ticket {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id])
  tierId    String
  tier      TicketTier @relation(fields: [tierId], references: [id])
  qrCode    String     @unique
  isUsed    Boolean    @default(false)
  createdAt DateTime   @default(now())

  payment TicketPayment?
}

model Venue {
  id          String   @id @default(uuid())
  ownerId     String
  owner       User     @relation("VenueOwner", fields: [ownerId], references: [id])
  name        String
  description String?
  address     String
  city        String
  latitude    Float?
  longitude   Float?
  capacity    Int
  pricePerDay Decimal  @db.Decimal(12, 2)
  isIndoor    Boolean  @default(true)
  hasWifi     Boolean  @default(false)
  hasParking  Boolean  @default(false)
  hasSound    Boolean  @default(false)
  hasStage    Boolean  @default(false)
  imageUrls   String[]
  createdAt   DateTime @default(now())

  events      Event[]
  bookings    VenueBooking[]
  reviews     Review[]
  ratingStats RatingStats?
}

model VenueBooking {
  id        String        @id @default(uuid())
  venueId   String
  venue     Venue         @relation(fields: [venueId], references: [id])
  eventId   String        @unique
  event     Event         @relation(fields: [eventId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    BookingStatus @default(PENDING)
  totalCost Decimal       @db.Decimal(12, 2)
  createdAt DateTime      @default(now())

  payment VenueBookingPayment?
}

model Service {
  id          String          @id @default(uuid())
  vendorId    String
  vendor      User            @relation("ServiceVendor", fields: [vendorId], references: [id])
  name        String
  category    ServiceCategory
  description String?
  priceFrom   Decimal         @db.Decimal(12, 2)
  imageUrls   String[]
  city        String
  createdAt   DateTime        @default(now())

  eventServices EventService[]
  reviews       Review[]
  ratingStats   RatingStats?
}

model EventService {
  id          String        @id @default(uuid())
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id])
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id])
  status      BookingStatus @default(PENDING)
  agreedPrice Decimal       @db.Decimal(12, 2)
  createdAt   DateTime      @default(now())

  payment ServicePayment?

  @@unique([eventId, serviceId])
}

model TicketPayment {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  ticketId     String          @unique
  ticket       Ticket          @relation(fields: [ticketId], references: [id])
  amount       Decimal         @db.Decimal(12, 2)
  commission   Decimal         @db.Decimal(12, 2)
  provider     PaymentProvider
  providerTxId String?
  status       PaymentStatus   @default(PENDING)
  createdAt    DateTime        @default(now())
}

model VenueBookingPayment {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  venueBookingId String          @unique
  venueBooking   VenueBooking    @relation(fields: [venueBookingId], references: [id])
  amount         Decimal         @db.Decimal(12, 2)
  commission     Decimal         @db.Decimal(12, 2)
  provider       PaymentProvider
  providerTxId   String?
  status         PaymentStatus   @default(PENDING)
  createdAt      DateTime        @default(now())
}

model ServicePayment {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  eventServiceId String          @unique
  eventService   EventService    @relation(fields: [eventServiceId], references: [id])
  amount         Decimal         @db.Decimal(12, 2)
  commission     Decimal         @db.Decimal(12, 2)
  provider       PaymentProvider
  providerTxId   String?
  status         PaymentStatus   @default(PENDING)
  createdAt      DateTime        @default(now())
}

model RatingStats {
  id        String   @id @default(uuid())

  venueId   String?  @unique
  venue     Venue?   @relation(fields: [venueId], references: [id])

  serviceId String?  @unique
  service   Service? @relation(fields: [serviceId], references: [id])

  eventId   String?  @unique
  event     Event?   @relation(fields: [eventId], references: [id])

  avg       Float    @default(0)
  count     Int      @default(0)
  one       Int      @default(0)
  two       Int      @default(0)
  three     Int      @default(0)
  four      Int      @default(0)
  five      Int      @default(0)

  updatedAt DateTime @updatedAt
}

model VolunteerApplication {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  eventId   String
  event     Event           @relation(fields: [eventId], references: [id])
  skills    String[]
  status    VolunteerStatus @default(PENDING)
  createdAt DateTime        @default(now())

  @@unique([userId, eventId])
}

model Review {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id])
  venueId   String?
  venue     Venue?   @relation(fields: [venueId], references: [id])
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([authorId, eventId])
  @@unique([authorId, venueId])
  @@unique([authorId, serviceId])
}
