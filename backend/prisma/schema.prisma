generator client {
  moduleFormat = "cjs"
  provider     = "prisma-client"
  output       = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ORGANIZER
  VENDOR
  VOLUNTEER
  PARTICIPANT
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentType {
  TICKET
  SQUARE
  SERVICE
  BOOST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentProvider {
  CLICK
  PAYME
}

enum VolunteerRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum BadgeStatus {
  PENDING
  APPROVED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role      @default(PARTICIPANT)
  avatarUrl    String?
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  events        Event[]
  tickets       Ticket[]
  reviews       Review[]
  volunteers    Volunteer[]
  ownedSquares  Square[]    @relation("SquareOwner")
  ownedServices Service[]   @relation("ServiceVendor")
  bookings      Booking[]
  payments      Payment[]
}

model Event {
  id          String      @id @default(uuid())
  organizerId String
  organizer   User        @relation(fields: [organizerId], references: [id], onDelete: Restrict)
  title       String
  description String?
  bannerUrl   String[]
  startDate   DateTime
  endDate     DateTime
  eventType   String
  capacity    Int
  status      EventStatus @default(DRAFT)
  squareId    String?
  square      Square?     @relation(fields: [squareId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tickets       Ticket[]
  ticketTiers   TicketTier[]
  eventServices EventService[]
  reviews       Review[]
  volunteers    Volunteer[]

  @@index([status, startDate])
  // Фильтр по типу: WHERE status='PUBLISHED' AND eventType=? ORDER BY startDate
  @@index([status, eventType, startDate])
  // Мои события организатора: WHERE organizerId=? ORDER BY createdAt DESC
  @@index([organizerId, createdAt(sort: Desc)])
  // FK на square — для "события в этой площадке"
  @@index([squareId])
}

model TicketTier {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  name      String
  price     Decimal  @db.Decimal(12, 2)
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
}

model Ticket {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id])
  tierId    String
  tier      TicketTier @relation(fields: [tierId], references: [id])
  pricePaid Decimal    @db.Decimal(12, 2)
  qrCode    String     @unique
  isUsed    Boolean    @default(false)
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  payment Payment?

  @@index([userId, createdAt(sort: Desc)])
  // Активные билеты: WHERE userId=? AND isUsed=false
  @@index([userId, isUsed])
  // Аналитика продаж по событию
  @@index([eventId, tierId])
}

model SquareCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  squares Square[]
}

model SquareCharacteristics {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  squares Square[]
}

model Square {
  id      String @id @default(uuid())
  ownerId String
  owner   User   @relation("SquareOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  categoryId String
  category   SquareCategory @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  address     String
  city        String
  latitude    Float?
  longitude   Float?
  capacity    Int

  characteristics SquareCharacteristics[]

  pricePerDay Decimal  @db.Decimal(12, 2)
  imageUrls   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events      Event[]
  bookings    Booking[]
  reviews     Review[]
  ratingStats RatingStats?
  boosts      Boost[]
  badges      SquareBadge[]

  @@index([city, categoryId])
  @@index([city, capacity]) // фильтр по вместимости
  @@index([city, pricePerDay]) // фильтр по цене/сортировка
  // Мои площадки вендора
  @@index([ownerId])
}

model ServiceCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  services Service[]
}

model Service {
  id          String          @id @default(uuid())
  vendorId    String
  vendor      User            @relation("ServiceVendor", fields: [vendorId], references: [id], onDelete: Restrict)
  categoryId  String
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  priceFrom   Decimal         @db.Decimal(12, 2)
  imageUrls   String[]
  city        String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  eventServices EventService[]
  reviews       Review[]
  ratingStats   RatingStats?
  boosts        Boost[]
  badges        ServiceBadge[]

  @@index([city, categoryId])
  @@index([city, priceFrom])
  @@index([vendorId])
}

model EventService {
  id          String        @id @default(uuid())
  eventId     String
  event       Event         @relation(fields: [eventId], references: [id])
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id])
  agreedPrice Decimal       @db.Decimal(12, 2)
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  booking Booking?

  @@unique([eventId, serviceId])
}

model Booking {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  squareId       String?
  square         Square?       @relation(fields: [squareId], references: [id])
  eventServiceId String?       @unique
  eventService   EventService? @relation(fields: [eventServiceId], references: [id])
  startDate      DateTime?
  endDate        DateTime?
  status         BookingStatus @default(PENDING)
  totalCost      Decimal       @db.Decimal(12, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  payment Payment?

  @@index([userId, status, createdAt(sort: Desc)])
  // КРИТИЧЕСКИЙ: проверка доступности площадки
  // WHERE squareId=? AND status='CONFIRMED' AND (startDate, endDate) overlaps (?, ?)
  @@index([squareId, status, startDate, endDate])
}

model Payment {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  type         PaymentType
  ticketId     String?         @unique
  ticket       Ticket?         @relation(fields: [ticketId], references: [id])
  bookingId    String?         @unique
  booking      Booking?        @relation(fields: [bookingId], references: [id])
  amount       Decimal         @db.Decimal(12, 2)
  commission   Decimal         @db.Decimal(12, 2)
  provider     PaymentProvider
  providerTxId String?
  status       PaymentStatus   @default(PENDING)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  boost        Boost?

  @@index([userId, createdAt(sort: Desc)])
  // Админка: реконсиляция по статусам
  @@index([status, createdAt])
}

model Boost {
  id        String   @id @default(uuid())
  paymentId String   @unique
  payment   Payment  @relation(fields: [paymentId], references: [id])
  squareId  String?
  square    Square?  @relation(fields: [squareId], references: [id])
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Badge {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  squareBadges  SquareBadge[]
  serviceBadges ServiceBadge[]
}

model SquareBadge {
  id        String      @id @default(uuid())
  squareId  String
  square    Square      @relation(fields: [squareId], references: [id])
  badgeId   String
  badge     Badge       @relation(fields: [badgeId], references: [id])
  status    BadgeStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([squareId, badgeId])
}

model ServiceBadge {
  id        String      @id @default(uuid())
  serviceId String
  service   Service     @relation(fields: [serviceId], references: [id])
  badgeId   String
  badge     Badge       @relation(fields: [badgeId], references: [id])
  status    BadgeStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([serviceId, badgeId])
}

model RatingStats {
  id        String   @id @default(uuid())
  squareId  String?  @unique
  square    Square?  @relation(fields: [squareId], references: [id])
  serviceId String?  @unique
  service   Service? @relation(fields: [serviceId], references: [id])
  avg       Float    @default(0)
  count     Int      @default(0)
  one       Int      @default(0)
  two       Int      @default(0)
  three     Int      @default(0)
  four      Int      @default(0)
  five      Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Review {
  id        String   @id @default(uuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id])
  squareId  String?
  square    Square?  @relation(fields: [squareId], references: [id])
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([squareId, createdAt(sort: Desc)])
  @@index([serviceId, createdAt(sort: Desc)])
  @@index([eventId, createdAt(sort: Desc)])
}

model VolunteerSkills {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  volunteers Volunteer[]
}

model Volunteer {
  id        String                 @id @default(uuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  eventId   String
  event     Event                  @relation(fields: [eventId], references: [id])
  skillId   String
  skill     VolunteerSkills        @relation(fields: [skillId], references: [id])
  status    VolunteerRequestStatus @default(PENDING)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@unique([userId, eventId])
  @@index([userId, status])
  @@index([eventId, status])
}
